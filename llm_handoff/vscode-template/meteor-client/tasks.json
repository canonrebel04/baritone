{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Meteor: build (skip tests)",
      "type": "shell",
      "command": "./gradlew",
      "args": ["--no-daemon", "build", "-x", "test"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Meteor: classes",
      "type": "shell",
      "command": "./gradlew",
      "args": ["--no-daemon", "classes"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Meteor: clean",
      "type": "shell",
      "command": "./gradlew",
      "args": ["--no-daemon", "clean"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
